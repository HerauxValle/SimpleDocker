        },
        {
          "label": "Backups",
          "icon": "\u25c8",
          "color": "DIM",
          "action": "fn:_manage_backups_menu"
        },
        {
          "label": "Blueprints",
          "icon": "\u25c8",
          "color": "DIM",
          "action": "fn:_blueprints_settings_menu"
        },
        {
