  "hooks": {
    "container_list": {
      "fn": "_hook_container_list"
    },
    "container_actions": {
      "fn": "_hook_container_actions",
      "args": [
        "cid"
      ]
    },
    "container_crons": {
      "fn": "_hook_container_crons",
      "args": [
        "cid"
      ]
    },
    "container_updates": {
      "fn": "_hook_container_updates",
      "args": [
        "cid"
      ]
    },
    "group_list": {
      "fn": "_hook_group_list"
    },
    "group_steps": {
      "fn": "_hook_group_steps",
      "args": [
        "gid"
      ]
    },
    "blueprint_list": {
      "fn": "_hook_blueprint_list"
    }
  }
}