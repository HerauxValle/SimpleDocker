# [N8N]
[container]
[meta]
name        = n8n
port        = 5678
dialogue    = Workflow automation
description = n8n — self-hosted workflow automation with 400+ integrations.
entrypoint  = node_modules/.bin/n8n start
storage_type= n8n

[env]
N8N_PORT              = 5678
N8N_HOST              = 0.0.0.0
N8N_PROTOCOL          = http
N8N_USER_FOLDER       = data
WEBHOOK_URL           = http://localhost:5678
N8N_ENCRYPTION_KEY    = generate:hex32
N8N_DIAGNOSTICS_ENABLED = false
N8N_VERSION_NOTIFICATIONS_ENABLED = false
POSTHOG_API_KEY       =

[storage]
data

[deps]
nodejs

[dirs]
data, logs

[npm]
n8n

[/container]