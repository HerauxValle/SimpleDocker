{
  "menus": {
    "main": {
      "header": "simpleDocker",
      "entries": [
        { "label": "Containers", "icon": "◈", "color": "GRN", "action": "menu:containers" },
        { "label": "Groups",     "icon": "▶", "color": "CYN", "action": "menu:groups" },
        { "label": "Blueprints", "icon": "◈", "color": "BLU", "action": "menu:blueprints" },
        { "type": "sep" },
        { "label": "Other",      "icon": "?", "color": "DIM", "action": "menu:other" },
        { "label": "Quit",       "icon": "×", "color": "RED", "action": "fn:_quit_menu" }
      ]
    },
    "containers": {
      "header": "Containers",
      "entries": [
        { "type": "dynamic", "hook": "container_list" },
        { "type": "sep" },
        { "label": "New container", "icon": "+", "color": "GRN", "action": "fn:_install_method_menu" },
        { "label": "← Back",        "color": "DIM", "action": "back" }
      ]
    },
    "container_item": {
      "header_fn": "_container_header",
      "entries": [
        { "label_key": "ct_start",       "icon": "▶", "color": "GRN", "action": "fn:_start_container",      "cond": "not_running" },
        { "label_key": "ct_stop",        "icon": "■", "color": "RED", "action": "fn:_stop_container",       "cond": "running" },
        { "label_key": "ct_restart",     "icon": "↺", "color": "YLW", "action": "fn:_restart_container",    "cond": "running" },
        { "label_key": "ct_attach",      "icon": "→", "color": "GRN", "action": "fn:_attach_container",     "cond": "running" },
        { "label_key": "ct_install",     "icon": "↓", "color": "DIM", "action": "fn:_install_container",    "cond": "not_installed" },
        { "label_key": "ct_update",      "icon": "↑", "color": "CYN", "action": "fn:_update_container",     "cond": "installed" },
        { "label_key": "ct_edit",        "icon": "◦", "color": "DIM", "action": "fn:_edit_container_bp" },
        { "label_key": "ct_terminal",    "icon": "◉", "color": "DIM", "action": "fn:_terminal_container",   "cond": "running" },
        { "type": "sep" },
        { "label_key": "ct_backups",     "icon": "◈", "action": "fn:_container_backups_menu",  "cond": "installed" },
        { "label_key": "ct_profiles",    "icon": "◧", "action": "fn:_persistent_storage_menu", "cond": "installed" },
        { "label_key": "ct_open_in",     "icon": "⊕", "action": "fn:_open_in_submenu",          "cond": "installed" },
        { "label_key": "ct_exposure",    "icon": "⬤", "action": "fn:_port_exposure_menu",       "cond": "installed" },
        { "type": "sep" },
        { "type": "dynamic", "hook": "container_actions" },
        { "type": "sep" },
        { "label_key": "ct_rename",    "action": "fn:_rename_container" },
        { "label_key": "ct_uninstall", "action": "fn:_uninstall_container", "cond": "installed" },
        { "label_key": "ct_remove",    "action": "fn:_remove_container",    "cond": "not_installed" },
        { "label": "← Back", "color": "DIM", "action": "back" }
      ]
    },
    "groups": {
      "header": "Groups",
      "entries": [
        { "type": "dynamic", "hook": "group_list" },
        { "type": "sep" },
        { "label": "New group", "icon": "+", "color": "GRN", "action": "fn:_create_group_menu" },
        { "label": "← Back",   "color": "DIM", "action": "back" }
      ]
    },
    "group_item": {
      "header_fn": "_group_header",
      "entries": [
        { "label": "▶  Start group", "color": "GRN", "action": "fn:_start_group" },
        { "label": "■  Stop group",  "color": "RED", "action": "fn:_stop_group" },
        { "label": "≡  Edit name/desc", "action": "fn:_edit_group" },
        { "label": "×  Delete group",   "color": "RED", "action": "fn:_delete_group" },
        { "type": "sep" },
        { "type": "dynamic", "hook": "group_steps" },
        { "type": "sep" },
        { "label": "← Back", "color": "DIM", "action": "back" }
      ]
    },
    "blueprints": {
      "header": "Blueprints",
      "entries": [
        { "type": "dynamic", "hook": "blueprint_list" },
        { "type": "sep" },
        { "label": "New blueprint",    "icon": "+",  "color": "GRN", "action": "fn:_new_blueprint_menu" },
        { "label": "⚙  Settings",      "icon": "⚙",  "color": "DIM", "action": "fn:_blueprints_settings_menu" },
        { "label": "← Back",           "color": "DIM", "action": "back" }
      ]
    },
    "blueprint_item": {
      "header_fn": "_blueprint_header",
      "entries": [
        { "label_key": "bp_edit",   "action": "fn:_edit_blueprint" },
        { "label_key": "bp_rename", "action": "fn:_rename_blueprint" },
        { "label_key": "bp_delete", "action": "fn:_delete_blueprint" },
        { "label": "← Back", "color": "DIM", "action": "back" }
      ]
    },
    "other": {
      "header": "Other",
      "entries": [
        { "type": "sep_label", "label": "Storage" },
        { "label": "Profiles & data",    "icon": "◈", "color": "DIM", "action": "fn:_persistent_storage_menu" },
        { "label": "Backups",            "icon": "◈", "color": "DIM", "action": "fn:_manage_backups_menu" },
        { "label": "Blueprints",         "icon": "◈", "color": "DIM", "action": "fn:_blueprints_settings_menu" },
        { "type": "sep_label", "label": "Plugins" },
        { "label": "Ubuntu base",        "icon": "◈", "color": "CYN", "action": "fn:_ubuntu_menu",  "status_fn": "_ubuntu_status" },
        { "label": "Caddy",              "icon": "◈", "color": "CYN", "action": "fn:_proxy_menu",   "status_fn": "_caddy_status" },
        { "label": "QRencode",           "icon": "◈", "color": "CYN", "action": "fn:_qrencode_menu","status_fn": "_qrencode_status" },
        { "type": "sep_label", "label": "Tools" },
        { "label": "Active processes",   "icon": "◈", "color": "DIM", "action": "fn:_active_processes_menu" },
        { "label": "Resource limits",    "icon": "◈", "color": "DIM", "action": "fn:_resources_menu" },
        { "label": "Blueprint preset",   "icon": "≡", "color": "DIM", "action": "fn:_show_blueprint_preset" },
        { "type": "sep_label", "label": "Caution" },
        { "label": "View logs",          "icon": "≡", "color": "DIM", "action": "fn:_logs_browser" },
        { "label": "Clear cache",        "icon": "⊘", "color": "DIM", "action": "fn:_clear_cache" },
        { "label": "Resize image",       "icon": "▷", "color": "DIM", "action": "fn:_resize_image" },
        { "label": "Manage Encryption",  "icon": "◈", "color": "DIM", "action": "fn:_enc_menu" },
        { "label": "Delete image file",  "icon": "×", "color": "RED", "action": "fn:_delete_image_file" },
        { "type": "sep" },
        { "label": "← Back", "color": "DIM", "action": "back" }
      ]
    }
  },
  "hooks": {
    "container_list":    { "fn": "_hook_container_list",    "returns": "entries" },
    "container_actions": { "fn": "_hook_container_actions", "returns": "entries", "args": ["cid"] },
    "group_list":        { "fn": "_hook_group_list",        "returns": "entries" },
    "group_steps":       { "fn": "_hook_group_steps",       "returns": "entries", "args": ["gid"] },
    "blueprint_list":    { "fn": "_hook_blueprint_list",    "returns": "entries" }
  },
  "action_types": {
    "menu:X": "push menu X onto stack, render it",
    "fn:X":   "call shell function X with current context args",
    "back":   "pop menu stack"
  }
}
